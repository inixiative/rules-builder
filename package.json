{
  "name": "@inixiative/rules-builder",
  "version": "0.18.1",
  "description": "Visual rule builder for @inixiative/json-rules",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "NODE_ENV=development bun test",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
    "check": "bun run typecheck && bun run typecheck:examples && bun run lint && bun run test",
    "example": "vite",
    "example:build": "tsc --noEmit -p tsconfig.examples.json && vite build",
    "prepublishOnly": "bun run check && bun run build",
    "lint": "biome check .",
    "prepare": "lefthook install"
  },
  "keywords": [
    "json-rules",
    "rule-builder",
    "visual-editor",
    "react",
    "form-builder"
  ],
  "author": "Aron Greenspan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inixiative/rules-builder.git"
  },
  "peerDependencies": {
    "@inixiative/json-rules": "^2.16.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@happy-dom/global-registrator": "^20.10.3",
    "@inixiative/config": "^0.5.6",
    "@inixiative/json-rules": "^2.16.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "happy-dom": "^20.10.3",
    "lefthook": "2.1.9",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vite": "^8.0.16"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.cjs"
    }
  },
  "packageManager": "bun@1.3.14"
}
