{
  "name": "@inixiative/rules-builder",
  "version": "0.0.1",
  "description": "Visual rule builder for @inixiative/json-rules",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "NODE_ENV=development bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "json-rules",
    "rule-builder",
    "visual-editor",
    "react",
    "form-builder"
  ],
  "author": "Aron Greenspan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inixiative/rules-builder"
  },
  "peerDependencies": {
    "@inixiative/json-rules": "^2.8.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.3",
    "@inixiative/json-rules": "^2.8.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "happy-dom": "^20.10.3",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    }
  }
}
